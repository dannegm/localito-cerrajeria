---
const photos = [
  { label: 'Apertura de chapa de auto', hint: 'Foto abriendo puerta de carro' },
  { label: 'Llave con chip programada', hint: 'Foto del equipo de codificación' },
  { label: 'Reparación de control remoto', hint: 'Foto del control terminado' },
  { label: 'Copia de chapa', hint: 'Foto de llaves duplicadas' },
]
---

<section class="py-16 sm:py-20 px-5 sm:px-8 bg-base">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-10">
      <div>
        <span class="inline-block text-amber-700 text-sm font-bold uppercase tracking-widest mb-2">Galería</span>
        <h2 class="font-heading font-extrabold text-3xl sm:text-4xl text-gray-900">
          Nuestro trabajo
        </h2>
        <p class="text-gray-600 font-semibold text-sm mt-2">Reemplaza estas fotos con imágenes reales del trabajo de Edwing</p>
      </div>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      {photos.map((p) => (
        <div class="group bg-amber-50 border-2 border-dashed border-amber-200 rounded-xl overflow-hidden aspect-square flex flex-col items-center justify-center gap-2 p-4 hover:border-amber-400 hover:bg-amber-100 transition-colors cursor-default">
          <svg class="w-10 h-10 text-amber-300 group-hover:text-amber-400 transition-colors" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0z" />
          </svg>
          <p class="text-amber-800 text-xs font-bold text-center leading-snug">{p.label}</p>
          <p class="text-amber-500 text-xs text-center leading-snug">{p.hint}</p>
        </div>
      ))}
    </div>
  </div>
</section>
