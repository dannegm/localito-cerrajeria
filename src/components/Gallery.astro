---
const photos = [
  {
    src: '/images/fotos-llaves.jpg',
    label: 'Cientos de modelos de llaves',
    hint: 'El catálogo más completo de la zona',
  },
  {
    src: '/images/foto-estacion-trabajo.jpg',
    label: 'Equipo de última generación',
    hint: 'Máquinas de corte profesional JMX y más',
  },
  {
    src: '/images/fotos-chapas.jpg',
    label: 'Chapas y cerraduras',
    hint: 'Stock completo para autos y casas',
  },
  {
    src: '/images/fotos-controles.jpg',
    label: 'Fundas y controles',
    hint: 'Protección para tu llave y control remoto',
  },
]
---

<section class="py-16 sm:py-20 px-5 sm:px-8 bg-base">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-10">
      <div>
        <span class="inline-block text-amber-700 text-sm font-bold uppercase tracking-widest mb-2">Galería</span>
        <h2 class="font-heading font-extrabold text-3xl sm:text-4xl text-gray-900">
          Nuestro trabajo
        </h2>
      </div>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      {photos.map((p) => (
        <div class="group flex flex-col gap-2">
          <div class="relative rounded-xl overflow-hidden aspect-square shadow-sm">
            <img
              src={p.src}
              alt={p.label}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
            <div class="absolute inset-0 bg-linear-to-t from-black/70 via-black/20 to-transparent hidden sm:flex flex-col justify-end p-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <p class="text-white text-base font-bold leading-snug">{p.label}</p>
              <p class="text-white/70 text-sm leading-snug mt-0.5">{p.hint}</p>
            </div>
          </div>
          <div class="sm:hidden px-1">
            <p class="text-gray-900 text-sm font-bold leading-snug">{p.label}</p>
            <p class="text-gray-500 text-xs leading-snug mt-0.5">{p.hint}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
