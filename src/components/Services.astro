---
const services = [
  {
    icon: `<svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5V6.75a4.5 4.5 0 1 1 9 0v3.75M3.75 21.75h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H3.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25z" /></svg>`,
    title: 'Apertura de Chapas',
    desc: 'Abrimos tu auto, moto o inmueble sin dañar la chapa. Llegamos a donde estás, de día o de noche.',
    tag: 'Sin daños',
  },
  {
    icon: `<svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 0 1 21.75 8.25z" /></svg>`,
    title: 'Llaves con Chip',
    desc: 'Codificamos y programamos llaves transponder y de control remoto para cualquier marca y modelo.',
    tag: 'Tecnología OEM',
  },
  {
    icon: `<svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.348 14.652a3.75 3.75 0 0 1 0-5.304m5.304 0a3.75 3.75 0 0 1 0 5.304m-7.425 2.121a6.75 6.75 0 0 1 0-9.546m9.546 0a6.75 6.75 0 0 1 0 9.546M5.106 18.894c-3.808-3.807-3.808-9.98 0-13.788m13.788 0c3.808 3.807 3.808 9.98 0 13.788M12 12h.008v.008H12V12z" /></svg>`,
    title: 'Clonación de Controles',
    desc: 'Clonamos y reparamos controles originales para que tu vehículo funcione exactamente como siempre.',
    tag: 'Original & compatible',
  },
  {
    icon: `<svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z" /></svg>`,
    title: 'Todo Tipo de Chapas',
    desc: 'Duplicados, instalación y reparación de chapas y llaves para autos, motos e inmuebles.',
    tag: 'Toda la gama',
  },
]
---

<section id="servicios" class="py-20 sm:py-28 px-5 sm:px-8 bg-surface">
  <div class="max-w-7xl mx-auto">

    <div class="max-w-2xl mb-12 sm:mb-16">
      <span class="inline-block text-amber-700 text-sm font-bold uppercase tracking-widest mb-3">
        Servicios
      </span>
      <h2 class="font-heading font-extrabold text-3xl sm:text-5xl text-gray-900 leading-tight">
        Todo lo que tu chapa<br class="hidden sm:block" /> y llave necesitan
      </h2>
      <p class="mt-4 text-gray-700 text-base sm:text-lg font-medium">
        Equipo especializado para resolver cualquier situación, desde una emergencia hasta una llave de repuesto.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5">
      {services.map((s, i) => (
        <div class="group relative bg-base border border-border rounded-2xl p-7 sm:p-8 overflow-hidden hover:border-amber-300 hover:shadow-md transition-all duration-300">
          <div class="absolute inset-0 bg-card-shine opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none rounded-2xl" aria-hidden="true"></div>

          <div class="flex items-center justify-between mb-5">
            <div class="w-12 h-12 rounded-xl bg-brand/20 flex items-center justify-center text-amber-700">
              <div class="w-6 h-6" set:html={s.icon} />
            </div>
            <span class="text-xs text-amber-800 font-bold bg-amber-100 border border-amber-200 px-3 py-1 rounded-full">
              {s.tag}
            </span>
          </div>

          <h3 class="font-heading font-bold text-xl sm:text-2xl text-gray-900 mb-2">
            {s.title}
          </h3>
          <p class="text-gray-700 text-sm sm:text-base leading-relaxed font-medium">
            {s.desc}
          </p>

          <div class="absolute bottom-5 right-6 font-display text-7xl text-gray-900/[0.04] select-none pointer-events-none leading-none">
            {String(i + 1).padStart(2, '0')}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
