---
const year = new Date().getFullYear()
const wa = 'https://wa.me/525522500001?text=Hola%2C%20necesito%20un%20cerrajero%2C%20%C2%BFest%C3%A1%20disponible%3F'
---

<footer class="border-t border-border bg-base py-10 px-5 sm:px-8">
  <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-5">

    <div class="flex items-center gap-2.5">
      <div class="w-7 h-7 rounded-lg bg-brand flex items-center justify-center shrink-0">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="#0B0E1A">
          <path d="M12 2a5 5 0 0 0-5 5c0 1.7.85 3.2 2.15 4.1V19a1 1 0 0 0 1 1h3.7a1 1 0 0 0 1-1v-1.5H16a1 1 0 0 0 1-1V15h1.5a1 1 0 0 0 1-1v-3.9A5 5 0 0 0 17 7a5 5 0 0 0-5-5zm0 2a3 3 0 0 1 3 3 3 3 0 0 1-1.1 2.3V18h-1v-8.7A3 3 0 0 1 9 9a3 3 0 0 1 3-3zm0 1.5a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3z"/>
        </svg>
      </div>
      <div>
        <p class="font-brand text-base font-extrabold leading-none whitespace-nowrap">
          <span class="text-gama font-black italic">GAMA</span>
          <span class="text-gray-900 font-bold italic"> EXPRESS</span>
        </p>
        <p class="text-gray-500 text-xs font-semibold mt-0.5">Edwing García</p>
      </div>
    </div>

    <nav class="flex items-center gap-6 text-sm">
      <a href="#servicios" class="text-gray-600 hover:text-gray-900 transition-colors font-semibold">Servicios</a>
      <a href="#nosotros" class="text-gray-600 hover:text-gray-900 transition-colors font-semibold">Nosotros</a>
      <a href="#contacto" class="text-gray-600 hover:text-gray-900 transition-colors font-semibold">Contacto</a>
    </nav>

    <p class="text-gray-500 text-xs text-center sm:text-right font-semibold">
      © {year} Cerrajería GAMA Express.
    </p>
  </div>
</footer>

<!-- WhatsApp flotante — solo mobile -->
<a
  href={wa}
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-6 right-5 sm:hidden z-40 flex items-center gap-2 bg-brand text-zinc-900 font-bold text-sm px-4 py-3 rounded-full shadow-[0_4px_24px_rgba(251,187,36,0.5)] hover:bg-amber-300 transition-all active:scale-95"
  aria-label="Contactar por WhatsApp"
>
  <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
  </svg>
  WhatsApp
</a>
