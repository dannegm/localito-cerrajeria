---
const testimonials = [
  {
    name: 'Ana M.',
    location: 'CDMX',
    stars: 5,
    text: 'Me quedé sin llaves a las 11 de la noche y en 20 minutos ya estaba adentro de mi carro. Muy rápido y honesto con el precio.',
  },
  {
    name: 'Carlos V.',
    location: 'Naucalpan',
    stars: 5,
    text: 'Programó la llave de mi Audi sin problema. Cobró lo que acordamos de inicio, sin sorpresas. Lo recomiendo sin pensarlo.',
  },
  {
    name: 'Sofía R.',
    location: 'Tlalnepantla',
    stars: 5,
    text: 'Excelente servicio. Me clonó el control de la moto en menos de una hora. Muy profesional y amable. Definitivamente vuelvo.',
  },
]
---

<section class="py-16 sm:py-20 px-5 sm:px-8 bg-navy">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-12">
      <span class="inline-block text-brand text-sm font-bold uppercase tracking-widest mb-3">Lo que dicen de nosotros</span>
      <h2 class="font-heading font-extrabold text-3xl sm:text-4xl text-white">
        Clientes que ya confían en GAMA
      </h2>
      <p class="text-gray-400 font-semibold text-sm mt-3">Reemplaza estos testimonios con reseñas reales de tus clientes</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
      {testimonials.map((t) => (
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 flex flex-col gap-4">
          <!-- Estrellas -->
          <div class="flex gap-1">
            {Array.from({ length: t.stars }).map(() => (
              <svg class="w-5 h-5 text-brand" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <p class="text-gray-200 text-sm leading-relaxed font-medium flex-1">"{t.text}"</p>

          <div class="flex items-center gap-2.5 pt-2 border-t border-white/10">
            <div class="w-8 h-8 rounded-full bg-brand/20 flex items-center justify-center shrink-0">
              <span class="text-brand text-sm font-bold">{t.name[0]}</span>
            </div>
            <div>
              <p class="text-white text-sm font-bold leading-none">{t.name}</p>
              <p class="text-gray-500 text-xs font-semibold mt-0.5">{t.location}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
