---
const wa = 'https://wa.me/525522500001?text=Hola%2C%20necesito%20un%20cerrajero%2C%20%C2%BFest%C3%A1%20disponible%3F'
---

<section id="nosotros" class="py-16 sm:py-24 px-5 sm:px-8 bg-surface border-t border-border">
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

    <!-- Foto Edwing -->
    <div class="relative order-2 lg:order-1">
      <div class="rounded-2xl overflow-hidden aspect-[3/4] sm:aspect-[4/3] lg:aspect-[3/4] max-w-sm mx-auto shadow-lg">
        <img
          src="/images/foto-about.jpg"
          alt="Edwing García, cerrajero"
          class="w-full h-full object-cover"
        />
      </div>

      <!-- Badge experiencia -->
      <div class="absolute top-4 -right-2 sm:-right-4 bg-brand rounded-2xl px-4 py-3 text-center shadow-lg">
        <p class="font-display text-4xl text-gray-900 leading-none">+10</p>
        <p class="text-gray-900 text-xs font-bold uppercase tracking-wide mt-0.5">años de<br/>experiencia</p>
      </div>
    </div>

    <!-- Texto -->
    <div class="order-1 lg:order-2">
      <span class="inline-block text-amber-700 text-sm font-bold uppercase tracking-widest mb-3">Quién soy</span>
      <h2 class="font-heading font-extrabold text-3xl sm:text-4xl lg:text-5xl text-gray-900 leading-tight mb-5">
        Hola, soy<br class="hidden sm:block" /> Edwing García
      </h2>
      <p class="text-gray-700 text-base sm:text-lg leading-relaxed font-medium mb-5">
        Llevo más de 10 años trabajando como cerrajero, especializado en vehículos de todo tipo. Me formé con los mejores y hoy cuento con equipo de última generación para programar llaves con chip, clonar controles y abrir cualquier chapa sin dañarla.
      </p>
      <p class="text-gray-700 text-base leading-relaxed font-medium mb-8">
        Soy una persona de palabra: te digo el precio antes de empezar y garantizo mi trabajo. Si algo no queda bien, vuelvo sin cobrar de más.
      </p>

      <!-- Garantías -->
      <div class="space-y-3 mb-8">
        {[
          'Presupuesto gratis antes de empezar',
          'Sin daños a tu chapa ni a tu carro',
          'Garantía en todos los trabajos',
          'Atención personalizada, no un call center',
        ].map((item) => (
          <div class="flex items-center gap-3">
            <div class="w-5 h-5 rounded-full bg-brand/20 flex items-center justify-center shrink-0">
              <svg class="w-3 h-3 text-amber-700" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
            </div>
            <span class="text-gray-800 text-sm font-semibold">{item}</span>
          </div>
        ))}
      </div>

      <a
        href={wa}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2.5 bg-brand hover:bg-amber-300 text-zinc-900 font-bold text-base px-6 py-3.5 rounded-xl transition-colors shadow-md"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
        </svg>
        Contáctame directo
      </a>
    </div>
  </div>
</section>
