---
const wa = 'https://wa.me/525522500001'
---

<section id="inicio" class="relative bg-base overflow-hidden">
  <!-- Pleca -->
  <div class="absolute lg:hidden -left-1/2 -top-[120px] sm:-top-[80px] z-0 w-[calc(100%*2)] h-60 bg-[#183657] origin-top rotate-6"></div>

  <!-- Franja amarilla decorativa top -->
  <div class="absolute top-0 inset-x-0 h-1 bg-brand" aria-hidden="true"></div>
  <!-- Trapecio navy — solo desktop, detrás de la foto -->
  <div
    class="absolute inset-y-0 right-0 w-[46%] pointer-events-none hidden lg:block"
    style="background-color: #183657; clip-path: polygon(14% 0%, 100% 0%, 100% 100%, 0% 100%);"
    aria-hidden="true"
  ></div>

  <div class="relative z-1 max-w-7xl mx-auto px-5 sm:px-8 py-16 sm:py-24 grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">

    <!-- Contenido izquierda -->

    <div class="sm:mt-8">
      <!-- Badge -->

      <div class="flex flex-col-reverse sm:flex-row">

        <div class="flex flex-col sm:w-1/2 items-start">
          <div class="inline-flex items-center gap-2 bg-amber-100 border border-amber-300 rounded-full px-4 py-1.5 mb-6">
            <span class="w-2 h-2 rounded-full bg-amber-600 animate-pulse shrink-0"></span>
            <span class="text-amber-800 text-xs font-bold tracking-widest uppercase">Servicio Express · 24/7</span>
          </div>

          <p class="text-gray-700 w-full text-base sm:text-lg leading-relaxed font-medium mb-8 max-w-lg text-balance">
            ¿Perdiste tus llaves? ¿Tu carro no abre? Llegamos a donde estás y resolvemos el problema rápido<span class="sm:hidden">, sin complicaciones y a buen precio</span>.
          </p>

          <!-- CTAs -->
          <div class="flex flex-col gap-3 mb-6">
            <a
              href={wa}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2.5 bg-brand hover:bg-amber-300 text-zinc-900 font-bold text-base px-6 py-3.5 rounded-xl transition-colors shadow-md"
            >
              <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
              </svg>
              Escribir por WhatsApp
            </a>
            <a
              href="tel:5522500001"
              class="inline-flex items-center justify-center gap-2.5 bg-navy hover:bg-blue-900 text-white font-bold text-base px-6 py-3.5 rounded-xl transition-colors"
            >
              <svg class="w-5 h-5 shrink-0 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75z" />
              </svg>
              Llamar ahora
            </a>
          </div>
        </div>

        <div class="relative flex justify-end">
          <img
            src="/logo.webp"
            alt="Cerrajería GAMA Express"
            class="h-40 sm:h-72 w-auto object-contain -mt-14 -mb-4 md:-mt-4 lg:mt-0 lg:mb-0"
          />
        </div>

      </div>

      <!-- Stats rápidos -->
      <div class="flex items-center gap-6 pt-4 border-t border-gray-200">
        <div>
          <p class="font-display text-3xl text-amber-700">+10</p>
          <p class="text-gray-600 text-xs font-semibold uppercase tracking-wide">Años de experiencia</p>
        </div>
        <div class="w-px h-10 bg-gray-200"></div>
        <div>
          <p class="font-display text-3xl text-amber-700">24/7</p>
          <p class="text-gray-600 text-xs font-semibold uppercase tracking-wide">Disponible siempre</p>
        </div>
        <div class="w-px h-10 bg-gray-200"></div>
        <div>
          <p class="font-display text-3xl text-amber-700">100%</p>
          <p class="text-gray-600 text-xs font-semibold uppercase tracking-wide">Garantizado</p>
        </div>
      </div>
    </div>

    <!-- Foto derecha -->
    <div class="relative">
      <!-- Foto principal placeholder -->
      <div class="relative bg-white/10 border-2 border-dashed border-white/30 rounded-2xl overflow-hidden aspect-[4/3] flex flex-col items-center justify-center gap-3 shadow-lg">
        <svg class="w-16 h-16 text-white/40" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0zM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
        </svg>
        <div class="text-center px-6">
          <p class="text-white/80 text-base font-bold">Foto de Edwing trabajando</p>
          <p class="text-white/50 text-sm mt-1">Reemplazar con imagen real<br/>(ej. abriendo un carro, con el equipo)</p>
        </div>
      </div>

      <!-- Tarjeta flotante — logo del negocio -->
      <div class="absolute -bottom-4 -left-4 sm:-left-6 bg-white border border-gray-200 rounded-xl px-4 py-3 shadow-xl flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-brand flex items-center justify-center shrink-0">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="#0B0E1A">
            <path d="M12 2a5 5 0 0 0-5 5c0 1.7.85 3.2 2.15 4.1V19a1 1 0 0 0 1 1h3.7a1 1 0 0 0 1-1v-1.5H16a1 1 0 0 0 1-1V15h1.5a1 1 0 0 0 1-1v-3.9A5 5 0 0 0 17 7a5 5 0 0 0-5-5zm0 2a3 3 0 0 1 3 3 3 3 0 0 1-1.1 2.3V18h-1v-8.7A3 3 0 0 1 9 9a3 3 0 0 1 3-3zm0 1.5a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3z"/>
          </svg>
        </div>
        <div>
          <p class="text-gray-900 text-sm font-bold leading-none">GAMA EXPRESS</p>
          <p class="text-gray-500 text-xs font-semibold mt-0.5">Cerrajería de confianza</p>
        </div>
      </div>
    </div>
  </div>
</section>
