---
import {
  siVolkswagen, siAudi, siBmw, siToyota, siHonda,
  siFord, siHyundai, siKia, siRenault, siNissan,
  siMazda, siFiat, siSeat,
} from 'simple-icons'

const brands = [
  { icon: siVolkswagen, name: 'Volkswagen' },
  { icon: siAudi,       name: 'Audi' },
  { icon: siBmw,        name: 'BMW' },
  { icon: siToyota,     name: 'Toyota' },
  { icon: siHonda,      name: 'Honda' },
  { icon: siFord,       name: 'Ford' },
  { icon: siHyundai,    name: 'Hyundai' },
  { icon: siKia,        name: 'Kia' },
  { icon: siRenault,    name: 'Renault' },
  { icon: siNissan,     name: 'Nissan' },
  { icon: siMazda,      name: 'Mazda' },
  { icon: siFiat,       name: 'Fiat' },
  { icon: siSeat,       name: 'SEAT' },
]
---

<section class="py-16 sm:py-20 px-5 sm:px-8 border-t border-border bg-base overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <p class="text-center text-gray-600 text-sm sm:text-base font-bold uppercase tracking-widest mb-10">
      Trabajamos con todas las marcas
    </p>

    <div class="relative">
      <div class="absolute left-0 top-0 bottom-0 w-16 sm:w-32 z-10 bg-gradient-to-r from-base to-transparent pointer-events-none" aria-hidden="true"></div>
      <div class="absolute right-0 top-0 bottom-0 w-16 sm:w-32 z-10 bg-gradient-to-l from-base to-transparent pointer-events-none" aria-hidden="true"></div>

      <div class="overflow-hidden">
        <div class="marquee-track flex items-center gap-10 sm:gap-14 w-max">
          {[...brands, ...brands].map((b) => (
            <div class="flex flex-col items-center gap-2 shrink-0 group cursor-default">
              <svg
                viewBox="0 0 24 24"
                fill="currentColor"
                class="w-9 h-9 sm:w-10 sm:h-10 text-gray-300 group-hover:text-gray-700 transition-colors duration-300"
                role="img"
                aria-label={b.name}
              >
                <path d={b.icon.path} />
              </svg>
              <span class="text-gray-400 group-hover:text-gray-700 text-xs font-semibold whitespace-nowrap transition-colors duration-300">
                {b.name}
              </span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .marquee-track {
    animation: marquee 36s linear infinite;
  }
  .marquee-track:hover {
    animation-play-state: paused;
  }
  @keyframes marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }
</style>
