---
const steps = [
  {
    n: '01',
    title: 'Nos contactas',
    desc: 'Llámanos o escríbenos por WhatsApp. Cuéntanos qué pasó y dónde estás.',
    icon: `<svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75z" /></svg>`,
  },
  {
    n: '02',
    title: 'Llegamos a ti',
    desc: 'Vamos directo donde estás. Sin que tengas que mover el carro ni buscar un taller.',
    icon: `<svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" /></svg>`,
  },
  {
    n: '03',
    title: 'Problema resuelto',
    desc: 'Trabajamos rápido y con cuidado. Te entregamos todo funcionando y con garantía.',
    icon: `<svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" /></svg>`,
  },
]
---

<section class="py-16 sm:py-20 px-5 sm:px-8 bg-amber-50 border-y border-amber-200">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-12">
      <span class="inline-block text-amber-700 text-sm font-bold uppercase tracking-widest mb-3">Así trabajamos</span>
      <h2 class="font-heading font-extrabold text-3xl sm:text-4xl text-gray-900">
        Sencillo y sin rodeos
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 sm:gap-8 relative">
      <!-- Línea conectora desktop -->
      <div class="hidden sm:block absolute top-8 left-[calc(16.67%+2rem)] right-[calc(16.67%+2rem)] h-px bg-amber-300" aria-hidden="true"></div>

      {steps.map((s) => (
        <div class="relative flex flex-col items-center text-center sm:items-center">
          <!-- Número + icono -->
          <div class="relative z-10 w-16 h-16 rounded-full bg-brand border-4 border-white shadow-md flex items-center justify-center text-gray-900 mb-4">
            <div class="w-7 h-7" set:html={s.icon} />
          </div>
          <span class="font-display text-4xl text-amber-200 absolute top-1 left-1/2 -translate-x-1/2 leading-none select-none pointer-events-none" aria-hidden="true">{s.n}</span>

          <h3 class="font-heading font-bold text-lg text-gray-900 mb-2">{s.title}</h3>
          <p class="text-gray-700 text-sm leading-relaxed font-medium max-w-xs">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
