---
const features = [
  {
    icon: `<svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
    title: 'Servicio Express',
    desc: 'Llegamos rápido a donde estás. Cada minuto cuenta en una emergencia.',
  },
  {
    icon: `<svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
    title: 'Trabajo Garantizado',
    desc: 'Todos nuestros servicios incluyen garantía. Si algo no funciona, volvemos sin costo.',
  },
  {
    icon: `<svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" /></svg>`,
    title: 'Disponible 24/7',
    desc: 'Las emergencias no avisan. Estamos disponibles cualquier día, a cualquier hora.',
  },
  {
    icon: `<svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>`,
    title: 'Precios Accesibles',
    desc: 'Presupuesto sin compromiso antes de comenzar. Sin sorpresas al final.',
  },
]
---

<section id="nosotros" class="py-20 sm:py-28 px-5 sm:px-8 bg-surface">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <div>
        <span class="inline-block text-amber-700 text-sm font-bold uppercase tracking-widest mb-3">
          ¿Por qué elegir GAMA?
        </span>
        <h2 class="font-heading font-extrabold text-3xl sm:text-5xl text-gray-900 leading-tight mb-5">
          Rápidos, confiables<br />y sin sorpresas
        </h2>
        <p class="text-gray-700 text-base sm:text-lg leading-relaxed mb-8 font-medium">
          Edwing García y su equipo llevan años resolviendo emergencias. Trabajamos con tecnología actualizada y somos transparentes con nuestros precios desde el primer momento.
        </p>

        <a
          href="https://wa.me/525522500001"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-amber-700 hover:text-amber-900 font-bold text-sm transition-colors group"
        >
          Pedir presupuesto ahora
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {features.map((f) => (
          <div class="bg-base border border-border rounded-2xl p-5 hover:border-amber-300 hover:shadow-sm transition-all duration-300 group">
            <div class="w-10 h-10 rounded-xl bg-brand/20 flex items-center justify-center text-amber-700 mb-4">
              <div class="w-5 h-5" set:html={f.icon} />
            </div>
            <h3 class="font-heading font-bold text-base text-gray-900 mb-1.5">
              {f.title}
            </h3>
            <p class="text-gray-700 text-sm leading-relaxed font-medium">
              {f.desc}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
