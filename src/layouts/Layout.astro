---
import '../styles/global.css'
const { title = 'Cerrajería GAMA Express | Apertura de Chapas y Llaves con Chip', description = 'Especialistas en apertura de chapas, codificación de llaves con chip, clonación y reparación de controles. Servicio express para todo tipo de vehículos. Edwing García.' } = Astro.props
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#09090B" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_MX" />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>

  </head>
  <body class="bg-base text-white font-sans antialiased">
    <slot />
  </body>
</html>
